---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
}
const {
  title,
  description = 'CV Bangun Sarana Makmur — solusi konstruksi & sarana makmur.',
  image = '/og-default.webp',
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        image: ogImage,
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        author: { '@type': 'Organization', name: 'CV Bangun Sarana Makmur' },
        publisher: { '@type': 'Organization', name: 'CV Bangun Sarana Makmur' },
        keywords: tags.join(', '),
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'CV Bangun Sarana Makmur',
        url: Astro.site?.href,
        description,
      };
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">CV Bangun Sarana Makmur</a>
      <nav>
        <a href="/">Beranda</a>
        <a href="/tentang">Tentang</a>
        <a href="/produk">Produk</a>
        <a href="/blog">Blog</a>
        <a href="/kontak">Kontak</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} CV Bangun Sarana Makmur.</p>
    </footer>
    <style is:global>
      :root { --ink: #1a1a1a; --muted: #655643; --accent: #b3261e; --bg: #fffff8; }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Georgia, 'Times New Roman', serif; color: var(--ink); background: var(--bg); line-height: 1.6; }
      .site-header, .site-footer { padding: 1rem 2rem; border-bottom: 1px solid #e5e0d8; }
      .site-footer { border-top: 1px solid #e5e0d8; border-bottom: none; color: var(--muted); font-size: .9rem; }
      .site-header { display: flex; justify-content: space-between; align-items: center; }
      .brand { font-weight: 700; text-decoration: none; color: var(--ink); }
      nav a { margin-left: 1.2rem; color: var(--muted); text-decoration: none; }
      nav a:hover { color: var(--accent); }
      main { max-width: 860px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
      a { color: var(--accent); }
    </style>
  </body>
</html>
