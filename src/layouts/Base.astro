---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
}
const {
  title,
  description = 'CV Bangun Sarana Makmur — pabrik besi satu atap: besi BRC, kawat duri, guard rail. Melayani seluruh Indonesia.',
  image = '/images/hero-project.svg',
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        image: ogImage,
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        author: { '@type': 'Organization', name: 'CV Bangun Sarana Makmur' },
        publisher: { '@type': 'Organization', name: 'CV Bangun Sarana Makmur' },
        keywords: tags.join(', '),
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'CV Bangun Sarana Makmur',
        url: Astro.site?.href,
        description,
      };
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Lewati ke konten</a>
    <header class="site-header" id="site-header">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M12 2v20M2 12h20" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
            <path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.5"/>
            <circle cx="12" cy="12" r="3.1" fill="currentColor"/>
          </svg>
        </span>
        <span class="brand-text">CV Bangun Sarana Makmur</span>
      </a>
      <nav id="primary-nav" class="primary-nav" aria-label="Navigasi utama">
        <a href="/#produk">Produk</a>
        <a href="/#satu-atap">Satu Atap</a>
        <a href="/#jangkauan">Jangkauan</a>
        <a href="/#kontak">Kontak</a>
        <a href="/blog">Blog</a>
      </nav>
      <div class="header-actions">
        <a class="btn btn-primary nav-cta" href="https://wa.me/628000000000">WhatsApp</a>
        <button
          class="nav-toggle"
          aria-expanded="false"
          aria-controls="primary-nav"
          aria-label="Buka menu"
        >
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>
    <main id="main" class="building">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <p class="footer-name">CV Bangun Sarana Makmur</p>
          <p class="footer-tag">
            Distributor material konstruksi satu atap. Melayani seluruh Indonesia, dari
            Sabang sampai Merauke.
          </p>
        </div>
        <nav class="footer-nav" aria-label="Navigasi footer">
          <a href="/#produk">Produk</a>
          <a href="/#satu-atap">Satu Atap</a>
          <a href="/#jangkauan">Jangkauan</a>
          <a href="/blog">Blog</a>
        </nav>
        <div class="footer-contact">
          <a class="btn btn-primary" href="https://wa.me/628000000000">Hubungi via WhatsApp</a>
          <a class="footer-mail" href="mailto:info@bsm.example.com">info@bsm.example.com</a>
        </div>
      </div>
      <p class="footer-legal">&copy; {new Date().getFullYear()} CV Bangun Sarana Makmur.</p>
    </footer>
    <script>
      const header = document.getElementById('site-header');
      const toggle = header?.querySelector('.nav-toggle');
      const nav = document.getElementById('primary-nav');
      toggle?.addEventListener('click', () => {
        const open = header!.classList.toggle('nav-open');
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Tutup menu' : 'Buka menu');
      });
      nav?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
          header?.classList.remove('nav-open');
          toggle?.setAttribute('aria-expanded', 'false');
        })
      );
      const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    </script>
    <style is:global>
      :root {
        /* ---- Sleek teal / graphite system (OKLCH) ---- */
        --bg: oklch(99% 0.002 95);
        --surface: oklch(97% 0.003 95);
        --surface-2: oklch(95% 0.004 95);
        --ink: oklch(22% 0.01 95);
        --ink-soft: oklch(30% 0.01 95);
        --muted: oklch(48% 0.01 95);
        --muted-2: oklch(62% 0.008 95);

        --red: oklch(58% 0.11 195);
        --red-deep: oklch(50% 0.10 195);
        --red-tint: oklch(95% 0.03 195);

        /* concrete slab tones (match section backgrounds so seams read as the slab breaking) */
        --concrete: oklch(99% 0.002 95);
        --concrete-2: oklch(97% 0.003 95);
        --steel-line: oklch(58% 0.008 250);

        --border: oklch(92% 0.004 95);
        --border-strong: oklch(86% 0.006 95);
        --hairline: oklch(90% 0 0 / 0.8);

        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 14px;
        --radius-pill: 999px;

        --space-sm: 8px;
        --space-md: 16px;
        --space-lg: 24px;
        --space-xl: 40px;
        --space-2xl: 64px;
        --space-3xl: 104px;

        --shadow-card: 0 1px 2px oklch(22% 0.01 95 / 0.06), 0 12px 30px -16px oklch(22% 0.01 95 / 0.18);
        --shadow-soft: 0 16px 40px -20px oklch(22% 0.01 95 / 0.22);
        --shadow-deep: 0 30px 70px -30px oklch(22% 0.01 95 / 0.3);

        --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
        --ease-quart: cubic-bezier(0.165, 0.84, 0.44, 1);

        --font-display: "Sora", system-ui, sans-serif;
        --font-body: "Geist", system-ui, -apple-system, sans-serif;
        --font-mono: "Geist Mono", ui-monospace, "SFMono-Regular", Menlo, monospace;

        --maxw: 1180px;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
      }

      body {
        margin: 0;
        font-family: var(--font-body);
        color: var(--ink);
        background: var(--bg);
        line-height: 1.62;
        font-size: 1.0625rem;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      /* ---------- Steel-frame background ----------
         The whole page sits inside the building's steel skeleton: sparse vertical
         uprights with occasional horizontal ties, fixed behind all content. Subtle,
         structural — a literal frame for a steel/construction brand, not decoration. */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          /* horizontal ties (sparse) */
          linear-gradient(180deg, var(--steel-line) 1px, transparent 1px),
          /* vertical uprights */
          linear-gradient(90deg, var(--steel-line) 1.5px, transparent 1.5px);
        background-size:
          100% 340px,
          72px 100%;
        background-position: 0 0, 0 0;
        opacity: 0.13;
        -webkit-mask-image:
          linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent),
          linear-gradient(180deg, transparent, #000 30%, #000 70%, transparent);
        -webkit-mask-composite: source-in;
        mask-image:
          linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent),
          linear-gradient(180deg, transparent, #000 30%, #000 70%, transparent);
        mask-composite: intersect;
      }
      /* content sits above the frame */
      .site-header, #main, .site-footer { position: relative; z-index: 1; }

      h1, h2, h3, h4 {
        font-family: var(--font-display);
        color: var(--ink);
        margin: 0;
        text-wrap: balance;
        font-weight: 600;
        letter-spacing: -0.02em;
      }

      p { text-wrap: pretty; }
      a { color: var(--red-deep); }

      ::selection { background: var(--red-tint); color: var(--red-deep); }

      /* ---------- Building metaphor: concrete slabs over a steel skeleton ----------
         Sections are concrete slabs. At each seam their edges crumble to reveal the
         steel pipes running through the cavity between them. Concrete = section bg. */
      .building { position: relative; }


      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--red);
        color: #fff;
        padding: 12px 16px;
        z-index: 200;
        border-radius: 0 0 var(--radius-sm) 0;
        font-weight: 700;
      }
      .skip-link:focus { left: 0; }

      /* ---------- Buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.01em;
        padding: 13px 26px;
        border-radius: var(--radius-md);
        text-decoration: none;
        cursor: pointer;
        border: 1px solid transparent;
        position: relative;
        transition: background 220ms var(--ease-out), color 220ms var(--ease-out),
          border-color 220ms var(--ease-out), transform 220ms var(--ease-out),
          box-shadow 220ms var(--ease-out);
      }
      .btn-primary {
        background: var(--red);
        color: #fff;
        border-color: var(--red-deep);
        box-shadow: 0 10px 24px -12px oklch(58% 0.11 195 / 0.6);
      }
      .btn-primary:hover { transform: translateY(-1px); background: var(--red-deep); }
      .btn-primary:focus-visible {
        outline: 2px solid var(--red-deep);
        outline-offset: 3px;
      }
      .btn-ghost {
        background: #fff;
        color: var(--ink);
        border-color: var(--border-strong);
        padding: 12px 25px;
      }
      .btn-ghost:hover {
        border-color: var(--red);
        color: var(--red-deep);
        background: var(--red-tint);
      }
      .btn-ghost.on-dark {
        color: #fff;
        border-color: oklch(100% 0 0 / 0.4);
        background: transparent;
      }
      .btn-ghost.on-dark:hover {
        background: oklch(100% 0 0 / 0.12);
        border-color: #fff;
        color: #fff;
      }

      /* ---------- Header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: var(--space-lg);
        background: oklch(99% 0.002 95 / 0.82);
        backdrop-filter: saturate(150%) blur(14px);
        -webkit-backdrop-filter: saturate(150%) blur(14px);
        border-bottom: 1px solid transparent;
        padding: 11px clamp(1rem, 4vw, 2rem);
        transition: border-color 220ms var(--ease-out), box-shadow 220ms var(--ease-out),
          background 220ms var(--ease-out);
      }
      .site-header.scrolled {
        border-bottom-color: var(--border);
        box-shadow: 0 14px 30px -22px oklch(22% 0.01 95 / 0.5);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 11px;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.02rem;
        letter-spacing: -0.01em;
        color: var(--ink);
        text-decoration: none;
        white-space: nowrap;
      }
      .brand-mark {
        display: grid;
        place-items: center;
        width: 34px; height: 34px;
        border-radius: 8px;
        color: #fff;
        background: var(--red);
        border: 1px solid var(--red-deep);
        box-shadow: inset 0 1px 0 oklch(100% 0 0 / 0.2);
      }
      .primary-nav {
        display: flex;
        justify-content: flex-end;
        gap: clamp(18px, 2.4vw, 34px);
      }
      .primary-nav a {
        color: var(--muted);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        padding: 6px 0;
        position: relative;
      }
      .primary-nav a::after {
        content: "";
        position: absolute;
        left: 0; right: 0; bottom: -2px;
        height: 2px;
        background: var(--red);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 240ms var(--ease-out);
      }
      .primary-nav a:hover,
      .primary-nav a.is-active { color: var(--ink); }
      .primary-nav a:hover::after,
      .primary-nav a.is-active::after { transform: scaleX(1); }
      .header-actions { display: flex; align-items: center; gap: 12px; }
      .nav-cta { white-space: nowrap; }
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 44px;
        height: 44px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        cursor: pointer;
      }
      .nav-toggle span {
        display: block;
        width: 20px; height: 2px;
        background: var(--ink);
        border-radius: 2px;
        transition: transform 200ms var(--ease-out), opacity 200ms var(--ease-out);
      }

      @media (max-width: 860px) {
        .site-header { grid-template-columns: 1fr auto; }
        .nav-toggle { display: flex; }
        .primary-nav {
          position: absolute;
          top: 100%;
          left: 0; right: 0;
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          background: oklch(11% 0.006 95 / 0.97);
          border-bottom: 1px solid var(--hairline);
          box-shadow: var(--shadow-deep);
          padding: 8px 0;
          display: none;
        }
        .site-header.nav-open .primary-nav { display: flex; }
        .primary-nav a {
          padding: 14px clamp(1rem, 4vw, 2rem);
          border-top: 1px solid var(--hairline);
          color: var(--muted);
        }
        .primary-nav a::after { display: none; }
        .site-header.nav-open .nav-toggle span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .site-header.nav-open .nav-toggle span:nth-child(2) { opacity: 0; }
        .site-header.nav-open .nav-toggle span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
      }

      /* ---------- Footer ---------- */
      .site-footer {
        background:
          radial-gradient(80% 140% at 50% -10%, oklch(60% 0.11 195 / 0.45), transparent 60%),
          linear-gradient(180deg, var(--red-deep), var(--red));
        color: #fff;
        padding: var(--space-3xl) clamp(1rem, 4vw, 2rem) var(--space-xl);
        margin-top: var(--space-3xl);
        position: relative;
      }
      .footer-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: var(--space-xl);
        align-items: start;
      }
      .footer-name {
        font-family: var(--font-display);
        font-weight: 700;
        color: #fff;
        margin: 0 0 10px;
        font-size: 1.1rem;
        letter-spacing: -0.01em;
      }
      .footer-tag { margin: 0; font-size: 0.95rem; max-width: 38ch; line-height: 1.55; color: oklch(82% 0.01 95); }
      .footer-nav { display: flex; flex-direction: column; gap: 11px; }
      .footer-nav a { color: oklch(80% 0.01 95); text-decoration: none; font-size: 0.95rem; transition: color 160ms var(--ease-out); }
      .footer-nav a:hover { color: #fff; }
      .footer-contact { display: flex; flex-direction: column; align-items: flex-start; gap: 14px; }
      .footer-mail { color: oklch(80% 0.01 95); text-decoration: none; font-size: 0.95rem; }
      .footer-mail:hover { color: #fff; }
      .footer-legal {
        max-width: var(--maxw);
        margin: var(--space-xl) auto 0;
        padding-top: var(--space-lg);
        border-top: 1px solid oklch(100% 0 0 / 0.14);
        font-size: 0.875rem;
        color: oklch(72% 0.01 95);
        text-align: center;
      }
      @media (max-width: 760px) {
        .footer-inner { grid-template-columns: 1fr; gap: var(--space-lg); }
      }
    </style>
  </body>
</html>
