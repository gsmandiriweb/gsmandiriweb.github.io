---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const all = await getCollection('blog');
const now = Date.now();
const latest = all
  .filter((p) => !p.data.trashed && new Date(p.data.pubDate).getTime() <= now)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const wa = (msg: string) => `https://wa.me/628000000000?text=${encodeURIComponent(msg)}`;

const products = [
  {
    name: 'Pagar BRC',
    kind: 'brc' as const,
    accent: 'Besi BRC',
    photo: '/photos/IMG_4077.webp',
    spec: 'Besi beton berkualitas · Standar SNI · Finishing HDG anti-karat untuk ketahanan jangka panjang di lapangan.',
  },
  {
    name: 'Kawat Duri',
    kind: 'wire' as const,
    accent: 'Kawat Duri',
    photo: '/photos/IMG_4068.webp',
    spec: 'Galvanis tahan cuaca · Roll panjang siap kirim untuk pagar pengaman proyek, lahan, dan perimeter.',
  },
  {
    name: 'Guard Rail',
    kind: 'rail' as const,
    accent: 'Guard Rail',
    photo: '/photos/IMG_4085.webp',
    spec: 'Pagar pengaman jalan · Material tebal · Memenuhi standar perkerasan SNI untuk konstruksi jalan raya.',
  },
];

const advantages = [
  {
    title: 'Harga langsung dari pabrik',
    body: 'BSM menampung produk dari beberapa pabrik sejenis, sehingga kontraktor mendapat satu sumber dengan harga pabrik — bukan harga eceran.',
  },
  {
    title: 'Satu sumber, banyak kebutuhan',
    body: 'Besi BRC, kawat duri, dan guard rail dalam satu pesanan. Satu mitra, satu administrasi, satu pengiriman ke lokasi proyek.',
  },
  {
    title: 'Stok lengkap & siap kirim',
    body: 'Gudang terisi dan logistik handal memastikan material tersedia tepat waktu, kapan pun proyek Anda butuh.',
  },
  {
    title: 'Jaminan kualitas & SNI',
    body: 'Setiap produk melewati seleksi ketat dan memenuhi standar SNI dengan lapisan anti-karat HDG.',
  },
];

const regions = [
  'Surabaya', 'Jakarta', 'Sidoarjo', 'Gresik', 'Malang', 'Semarang',
  'Yogyakarta', 'Bandung', 'Kalimantan', 'Sulawesi', 'Papua', 'Sumatera',
];

const factories = ['Pabrik BRC', 'Pabrik Kawat', 'Pabrik Rail'];

// Curated gallery from the real site photos.
const gallery = [
  '/photos/IMG_4077.webp',
  '/photos/IMG_4085.webp',
  '/photos/IMG_4068.webp',
  '/photos/IMG_4082.webp',
  '/photos/IMG_4071.webp',
  '/photos/IMG_4086.webp',
  '/photos/IMG_4078.webp',
  '/photos/IMG_4064.webp',
];
---

<Base
  title="CV Bangun Sarana Makmur — Distributor Material Konstruksi One-Stop"
  description="BSM menampung besi BRC, kawat duri, dan guard rail dari beberapa pabrik menjadi satu sumber andal untuk proyek Anda. Melayani seluruh Indonesia."
>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <span class="eyebrow">Distributor Material Konstruksi</span>
        <h1>Satu <span class="hl">sumber</span> untuk kebutuhan material proyek Anda</h1>
        <p class="hero-lead">
          Kami menampung besi BRC, kawat duri, dan guard rail dari beberapa pabrik menjadi
          <strong>satu suplai one-stop</strong> untuk kontraktor dan proyek di seluruh Indonesia.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href={wa('Halo BSM, saya ingin minta penawaran untuk material proyek.')}>
            Hubungi via WhatsApp
          </a>
          <a class="btn btn-ghost" href="#produk">Lihat produk</a>
        </div>
        <ul class="hero-stats">
          <li><span class="stat-num">10+</span><span class="stat-label">Tahun</span></li>
          <li><span class="stat-num">SNI</span><span class="stat-label">Terstandarisasi</span></li>
          <li><span class="stat-num">S–M</span><span class="stat-label">Sabang–Merauke</span></li>
        </ul>
      </div>

      <div class="hero-media reveal">
        <!-- Real site photo. three.js low-poly accent layers on top after load;
             SVG/gradient poster is the no-JS + reduced-motion fallback. -->
        <img
          src="/photos/IMG_4077.webp"
          alt="Proyek konstruksi BSM: material pagar dan struktur baja di lokasi"
          width="1600" height="1067" loading="eager" decoding="async"
        />
        <span class="hero-stamp">Satu Sumber · One-Stop</span>
      </div>
    </div>
  </section>

  <!-- ============================ PROOF STRIP ============================ -->
  <section class="proof">
    <div class="proof-inner">
      <p class="proof-lead">
        <strong>Terpercaya</strong> untuk proyek &amp; instansi pemerintah di seluruh Indonesia.
      </p>
      <ul class="proof-facts">
        <li><span class="fact-mark" aria-hidden="true"></span>10+ tahun</li>
        <li><span class="fact-mark" aria-hidden="true"></span>Standar SNI</li>
        <li><span class="fact-mark" aria-hidden="true"></span>Sabang–Merauke</li>
        <li><span class="fact-mark" aria-hidden="true"></span>Langsung dari pabrik</li>
      </ul>
    </div>
  </section>


  <!-- ============================ PRODUK ============================ -->
  <section id="produk" class="section">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Produk Inti</span>
        <h2>Tiga material, satu pesanan</h2>
        <p class="section-intro">
          Ditarik langsung dari pabrik dan dikirim sebagai satu pengiriman ke lokasi proyek Anda.
        </p>
      </header>
      <div class="product-list">
        {
          products.map((p, i) => (
            <article class="product-row reveal" class:list={[i % 2 === 1 && 'reverse']}>
              <div class="product-media">
                <img src={p.photo} alt={`${p.name} — ${p.accent}`} width="1200" height="800" loading="lazy" decoding="async" />
                <span class="product-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="product-copy">
                <span class="product-kicker">{p.accent}</span>
                <h3>{p.name}</h3>
                <p>{p.spec}</p>
                <a class="btn btn-primary" href={wa(`Halo BSM, saya ingin minta penawaran untuk ${p.name}.`)}>
                  Minta penawaran
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>


  <!-- ============================ SATU ATAP / ONE-STOP ============================ -->
  <section id="satu-atap" class="section section-soft">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Satu Atap</span>
        <h2>Beberapa pabrik. Satu sumber suplai.</h2>
        <p class="section-intro">
          Pabrik tidak menjual eceran. BSM menggabungkan beberapa item sejenis menjadi satu
          pasokan andal — Anda tak perlu menghubungi pabrik demi pabrik.
        </p>
      </header>

      <div class="flow reveal">
        <div class="flow-col">
          <p class="flow-label">Penyuplai</p>
          <ul class="flow-list">
            {factories.map((f) => (
              <li><span class="node-dot" aria-hidden="true"></span>{f}</li>
            ))}
          </ul>
        </div>
        <div class="flow-arrow" aria-hidden="true">
          <span class="flow-core">BSM</span>
        </div>
        <div class="flow-col">
          <p class="flow-label">Untuk Anda</p>
          <ul class="flow-list">
            {['Satu pesanan', 'Satu administrasi', 'Satu pengiriman'].map((o) => (
              <li class="out"><span class="node-dot red" aria-hidden="true"></span>{o}</li>
            ))}
          </ul>
        </div>
      </div>

      <ul class="advantage-grid stagger">
        {
          advantages.map((a) => (
            <li class="advantage">
              <span class="advantage-num" aria-hidden="true">{String(advantages.indexOf(a) + 1).padStart(2, '0')}</span>
              <h3>{a.title}</h3>
              <p>{a.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============================ JANGKAUAN ============================ -->
  <section id="jangkauan" class="section section-coverage">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Jangkauan</span>
        <h2>Dari Sabang sampai Merauke</h2>
        <p class="section-intro">
          BSM melayani pengadaan material proyek di seluruh nusantara — bukan hanya Jawa.
          Satu mitra untuk lokasi proyek di Sumatera, Jawa, Kalimantan, Sulawesi, hingga Papua.
        </p>
      </header>
      <div class="coverage-grid reveal">
        <div class="map-wrap">
          <img src="/images/indonesia-map.svg" alt="Peta jangkauan pengiriman BSM di seluruh Indonesia, dari Sabang sampai Merauke" width="1411" height="520" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[...regions, ...regions, ...regions].map((r) => (
          <span class="marquee-item">{r}</span>
        ))}
      </div>
    </div>
  </section>


  <!-- ============================ GALERI PROYEK ============================ -->
  <section id="galeri" class="section">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Galeri Proyek</span>
        <h2>Material BSM di lapangan</h2>
        <p class="section-intro">Dokumentasi langsung dari proyek dan lokasi pengiriman kami di seluruh Indonesia.</p>
      </header>
      <ul class="gallery-grid stagger">
        {
          gallery.map((src) => (
            <li class="gallery-item reveal">
              <img src={src} alt="Dokumentasi proyek BSM" width="800" height="600" loading="lazy" decoding="async" />
            </li>
          ))
        }
      </ul>
    </div>
  </section>


  <!-- ============================ CTA BAND ============================ -->
  <section id="kontak" class="cta-band">
    <div class="container cta-inner reveal">
      <span class="eyebrow on-dark">Kontak</span>
      <h2>Butuh penawaran untuk proyek Anda?</h2>
      <p>Hubungi tim BSM untuk konsultasi produk dan estimasi pengiriman ke lokasi proyek.</p>
      <div class="cta-actions">
        <a class="btn btn-primary on-light" href={wa('Halo BSM, saya ingin konsultasi & minta penawaran material proyek.')}>
          WhatsApp
        </a>
        <a class="btn btn-ghost on-dark" href="mailto:info@bsm.example.com">Email kami</a>
      </div>
    </div>
  </section>

  <!-- ============================ BLOG ============================ -->
  {
    latest.length > 0 && (
      <section class="section section-soft">
        <div class="container">
          <header class="section-head reveal">
            <span class="eyebrow">Blog</span>
            <h2>Wawasan terbaru</h2>
            <p class="section-intro">Catatan proyek, material, dan pembaruan dari tim BSM.</p>
          </header>
          <ul class="post-list stagger">
            {latest.map((post) => (
              <li class="post-item reveal">
                <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
                <div class="post-meta">
                  <time datetime={new Date(post.data.pubDate).toISOString()}>
                    {new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {' · '}{post.data.category}
                </div>
              </li>
            ))}
          </ul>
          <a class="btn btn-ghost all-posts" href="/blog">Lihat semua artikel →</a>
        </div>
      </section>
    )
  }

  <script>
    // Lazy-load scroll animations (GSAP) after the page has painted.
    // Guarded: reduced-motion and no-JS users see fully visible content.
    window.addEventListener('load', () => {
      import('../scripts/scroll-anim')
        .then((m) => m.initScrollAnim())
        .catch(() => {});
    });
  </script>

  <style>
    .container { max-width: var(--maxw); margin: 0 auto; padding-inline: clamp(1rem, 4vw, 2rem); position: relative; z-index: 1; }
    .section { padding-block: clamp(72px, 10vw, 132px); position: relative; }
    .section-soft {
      background:
        radial-gradient(90% 70% at 50% -10%, oklch(100% 0 0), transparent 60%),
        linear-gradient(180deg, #fff 0%, var(--surface) 100%);
    }
    .section-head { max-width: 56ch; margin-bottom: var(--space-2xl); }
    .section-head h2 { font-size: clamp(2.1rem, 4.6vw, 3.4rem); letter-spacing: -0.03em; line-height: 1.05; margin: 16px 0 0; }
    .section-intro { color: var(--muted); margin: 18px 0 0; font-size: 1.12rem; max-width: 52ch; }
    .eyebrow {
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--red);
      display: block;
    }
    .eyebrow.on-dark { color: #fff; opacity: 0.85; }
    :global(#satu-atap) { overflow: hidden; }
    :global(#satu-atap)::before {
      content: ""; position: absolute; left: 0; right: 0; top: 0; height: 4px;
      background: linear-gradient(90deg, transparent, var(--red) 30%, var(--red) 70%, transparent);
      opacity: 0.55;
    }
    /* subtle gradient sheen on product photo hover */
    .product-media::after {
      content: ""; position: absolute; inset: 0; pointer-events: none; opacity: 0;
      background: linear-gradient(120deg, transparent 40%, oklch(58% 0.11 195 / 0.10) 100%);
      transition: opacity 360ms var(--ease-out);
    }
    .product-media:hover::after { opacity: 1; }

    /* ---------- HERO ---------- */
    .hero {
      position: relative; padding-block: clamp(48px, 7vw, 104px) clamp(56px, 8vw, 104px); overflow: hidden;
      background:
        radial-gradient(120% 100% at 88% -15%, oklch(95% 0.03 195), transparent 52%),
        radial-gradient(90% 90% at -8% 10%, oklch(58% 0.11 195 / 0.12), transparent 55%),
        var(--bg);
    }
    /* bold blueprint dot grid, brand-tinted, concentrated top-right but clearly visible */
    .hero::before {
      content: ""; position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background-image: radial-gradient(oklch(58% 0.11 195 / 0.30) 1.8px, transparent 2px);
      background-size: 22px 22px;
      -webkit-mask-image: radial-gradient(95% 90% at 82% -5%, #000, transparent 78%);
      mask-image: radial-gradient(95% 90% at 82% -5%, #000, transparent 78%);
    }
    /* secondary fine dot layer for depth across the whole hero */
    .hero::after {
      content: ""; position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background-image: radial-gradient(oklch(58% 0.11 195 / 0.12) 1px, transparent 1.3px);
      background-size: 11px 11px;
      -webkit-mask-image: linear-gradient(180deg, #000, transparent 70%);
      mask-image: linear-gradient(180deg, #000, transparent 70%);
    }
    .hero-glow {
      position: absolute; top: -25%; right: -12%; width: 56vw; height: 56vw; max-width: 800px; max-height: 800px;
      background: radial-gradient(circle at 70% 30%, oklch(58% 0.11 195 / 0.32), transparent 60%);
      z-index: 0; pointer-events: none;
    }
    .hero-grid {
      position: relative; z-index: 1;
      display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(32px, 5vw, 72px); align-items: center;
    }
    .hero h1 { font-size: clamp(2.6rem, 6vw, 4.6rem); line-height: 1.02; letter-spacing: -0.03em; margin: 18px 0 0; }
    .hero h1 .hl { color: var(--red); }
    .hero-lead { color: var(--muted); font-size: 1.2rem; margin: 26px 0 0; max-width: 50ch; }
    .hero-lead strong { color: var(--ink); font-weight: 700; }
    .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; }
    .hero-stats { list-style: none; margin: 42px 0 0; padding: 26px 0 0; border-top: 1px solid var(--border); display: flex; gap: clamp(20px, 4vw, 44px); flex-wrap: wrap; }
    .hero-stats li { display: flex; flex-direction: column; gap: 2px; }
    .stat-num { font-family: var(--font-display); font-weight: 700; font-size: 1.5rem; letter-spacing: -0.02em; color: var(--red); font-variant-numeric: tabular-nums; }
    .stat-label { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }

    .hero-media {
      border-radius: var(--radius-lg); overflow: hidden; position: relative;
      background: var(--surface-2); border: 1px solid var(--border); box-shadow: var(--shadow-card);
      aspect-ratio: 3 / 2;
    }
    .hero-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .hero-stamp {
      position: absolute; left: 18px; bottom: 18px;
      background: var(--red); color: #fff; font-family: var(--font-body); font-weight: 800;
      font-size: 0.78rem; letter-spacing: 0.04em; padding: 9px 14px; border-radius: var(--radius-sm);
      box-shadow: 0 8px 20px -10px oklch(58% 0.11 195 / 0.7);
    }

    /* ---------- PROOF STRIP ---------- */
    .proof {
      background:
        radial-gradient(70% 200% at 18% 50%, oklch(58% 0.11 195 / 0.22), transparent 60%),
        linear-gradient(180deg, oklch(20% 0.01 95), oklch(16% 0.01 95));
      color: #fff;
      position: relative;
    }
    .proof-inner {
      max-width: var(--maxw); margin: 0 auto; padding: clamp(26px, 3.4vw, 40px) clamp(1rem, 4vw, 2rem);
      display: flex; flex-wrap: wrap; align-items: center; gap: clamp(20px, 4vw, 52px);
    }
    .proof-lead { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.1rem, 2.2vw, 1.45rem); letter-spacing: -0.01em; margin: 0; flex: 1 1 240px; color: #fff; }
    .proof-lead strong { color: var(--red); }
    .proof-facts { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 12px 26px; }
    .proof-facts li { display: flex; align-items: center; gap: 9px; font-weight: 600; font-size: 0.92rem; color: oklch(85% 0.01 95); }
    .fact-mark { width: 9px; height: 9px; border-radius: 2px; background: var(--red); flex: none; }

    /* ---------- PRODUCT ROWS ---------- */
    .product-list { display: grid; gap: clamp(36px, 5vw, 72px); }
    .product-row { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 4vw, 64px); align-items: center; }
    .product-row.reverse .product-media { order: 2; }
    .product-media { position: relative; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); background: var(--surface-2); box-shadow: var(--shadow-card); aspect-ratio: 3 / 2; }
    .product-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .product-num {
      position: absolute; left: 16px; top: 12px;
      font-family: var(--font-display); font-weight: 800; font-size: 2rem; line-height: 1;
      color: #fff; letter-spacing: -0.03em; text-shadow: 0 2px 16px oklch(0% 0 0 / 0.5);
    }
    .product-kicker { font-family: var(--font-body); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--red); display: block; }
    .product-copy h3 { font-size: clamp(1.7rem, 3vw, 2.4rem); letter-spacing: -0.025em; margin: 12px 0 0; }
    .product-copy p { color: var(--muted); font-size: 1.05rem; margin: 14px 0 26px; max-width: 46ch; }

    /* ---------- ONE-STOP FLOW ---------- */
    .flow {
      display: grid; grid-template-columns: 1fr auto 1fr; gap: clamp(20px, 4vw, 56px); align-items: center;
      margin-bottom: var(--space-2xl);
      background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg);
      padding: clamp(28px, 4vw, 48px); box-shadow: var(--shadow-card);
    }
    .flow-label { font-family: var(--font-body); font-weight: 700; font-size: 0.76rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 16px; }
    .flow-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
    .flow-list li { display: flex; align-items: center; gap: 12px; padding: 14px 18px; border-radius: var(--radius-md); background: var(--surface); border: 1px solid var(--border); font-weight: 600; color: var(--ink-soft); }
    .flow-list li.out { justify-content: flex-end; background: var(--red-tint); border-color: oklch(58% 0.11 195 / 0.25); color: var(--red-deep); }
    .node-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--ink-soft); flex: none; }
    .node-dot.red { background: var(--red); }
    .flow-arrow { display: grid; place-items: center; }
    .flow-core {
      font-family: var(--font-display); font-weight: 800; font-size: 1.5rem; letter-spacing: 0.02em;
      color: #fff; background: var(--red); width: 84px; height: 84px; border-radius: 50%;
      display: grid; place-items: center; box-shadow: 0 14px 30px -14px oklch(58% 0.11 195 / 0.6);
      position: relative;
    }
    /* concentric brushed-steel ring around the hub */
    .flow-core::before {
      content: ""; position: absolute; inset: -12px; border-radius: 50%;
      padding: 2px;
      background: conic-gradient(from 210deg,
        oklch(82% 0.005 250), oklch(46% 0.008 250) 25%,
        oklch(88% 0.004 250) 50%, oklch(42% 0.008 250) 75%, oklch(82% 0.005 250));
      -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
      -webkit-mask-composite: xor; mask-composite: exclude;
    }

    .advantage-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(28px, 3.4vw, 52px); }
    .advantage { border-top: 2px solid var(--red); padding-top: 24px; }
    .advantage-num { font-family: var(--font-display); font-weight: 800; font-size: 1.6rem; color: var(--red); letter-spacing: -0.02em; display: block; line-height: 1; }
    .advantage h3 { font-size: 1.35rem; margin: 16px 0 10px; color: var(--ink); letter-spacing: -0.015em; }
    .advantage p { color: var(--muted); font-size: 1rem; margin: 0; max-width: 42ch; }

    /* ---------- COVERAGE ---------- */
    .coverage-grid { display: block; }
    .map-wrap {
      /* transparent, breaks out of the container and centers in the viewport */
      background: transparent;
      width: 96vw;
      margin-left: 50%;
      transform: translateX(-50%);
    }
    .map-wrap img { width: 100%; height: auto; display: block; }
