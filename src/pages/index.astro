---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { waLink as wa, EMAIL } from '../config/contact';
import Magnetic from '../lib/motion-core/magnetic/Magnetic.svelte';
import Marquee from '../lib/motion-core/marquee/Marquee.svelte';
import ScrollCue from '../components/react/ScrollCue.tsx';
import IndonesiaMap from '../components/react/IndonesiaMap.tsx';

const all = await getCollection('blog');
const now = Date.now();
const latest = all
  .filter((p) => !p.data.trashed && new Date(p.data.pubDate).getTime() <= now)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const products = [
  {
    name: 'Pagar BRC',
    accent: 'Besi BRC',
    slug: 'pagar-brc',
    photo: '/photos/IMG_4077.webp',
    spec: 'Besi beton kualitas SNI dengan finishing Hot Dip Galvanize anti-karat, siap pasang untuk pagar proyek dan perimeter.',
    cta: 'Lihat detail Pagar BRC',
  },
  {
    name: 'Kawat Duri',
    accent: 'Kawat pengaman',
    slug: 'kawat-duri',
    photo: '/photos/generated/wire.webp',
    spec: 'Kawat duri galvanis tahan cuaca dalam roll panjang — ideal untuk keamanan lahan, gudang, dan area proyek.',
    cta: 'Lihat detail Kawat Duri',
  },
  {
    name: 'Guard Rail',
    accent: 'Guard Rail jalan',
    slug: 'guard-rail',
    photo: '/photos/generated/rail.webp',
    spec: 'Pengaman jalan bahan tebal dengan standar perkerasan SNI untuk keselamatan infrastruktur.',
    cta: 'Lihat detail Guard Rail',
  },
];

const advantages = [
  { title: 'Harga langsung dari pabrik', body: 'BSM menggabungkan produk dari beberapa pabrik sejenis, sehingga Anda mendapat harga pabrik — bukan harga eceran.' },
  { title: 'Satu sumber, banyak kebutuhan', body: 'BRC, kawat duri, dan guard rail dalam satu pesanan. Satu mitra, satu administrasi, satu pengiriman.' },
  { title: 'Stok lengkap & siap kirim', body: 'Gudang terisi dan logistik tersebar memastikan material sampai tepat waktu ke lokasi proyek.' },
  { title: 'Jaminan kualitas & SNI', body: 'Setiap produk melewati seleksi ketat dan memenuhi standar SNI.' },
];

const regions = ['Surabaya', 'Jakarta', 'Sidoarjo', 'Gresik', 'Malang', 'Semarang', 'Yogyakarta', 'Bandung', 'Kalimantan', 'Sulawesi', 'Papua', 'Sumatera'];

const gallery = ['/photos/IMG_4077.webp', '/photos/IMG_4085.webp', '/photos/IMG_4068.webp', '/photos/IMG_4089.webp', '/photos/IMG_4098.webp', '/photos/IMG_4071.webp'];

const proofTicks = ['SNI', '10+ tahun pengalaman', 'Sabang–Merauke', 'Pemasok pemerintah', 'Harga pabrik', 'Stok siap kirim', 'Satu pesanan, satu kiriman'];
---

<Base
  title="CV Bangun Sarana Makmur — Distributor Material Konstruksi One-Stop"
  description="BSM menampung besi BRC, kawat duri, dan guard rail dari beberapa pabrik menjadi satu sumber andal untuk proyek Anda. Melayani seluruh Indonesia."
>
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid container">
      <div class="hero-copy reveal">
        <span class="eyebrow">Distributor Material Konstruksi</span>
        <h1 class="display hero-title" data-word-reveal>Satu sumber untuk semua kebutuhan material proyek Anda</h1>
        <p class="hero-lead">Kami mempermudah pengadaan besi BRC, kawat duri, dan guard rail menjadi satu pasokan yang andal, dari pabrik langsung ke lokasi proyek Anda.</p>
        <div class="hero-cta">
          <Magnetic client:load>
            <a class="btn btn-primary" href={wa('Halo BSM, saya ingin minta penawaran untuk material proyek.')}>Hubungi via WhatsApp</a>
          </Magnetic>
          <a class="btn btn-ghost" href="#produk">Lihat produk</a>
        </div>
      </div>
      <div class="hero-media-wrap">
        <div class="hero-halo" aria-hidden="true"></div>
        <div class="hero-media">
          <img src="/photos/IMG_4077.webp" alt="Proyek BSM: material pagar dan struktur baja di lokasi konstruksi" width="1600" height="1067" loading="eager" decoding="async" data-parallax-speed="0.15" />
        </div>
      </div>
    </div>
    <div class="hero-proof container">
      <ul>
        <li><strong>10+</strong> tahun berpengalaman</li>
        <li><strong>SNI</strong> terstandarisasi</li>
        <li><strong>Sabang–Merauke</strong></li>
        <li><strong>Pemasok pemerintah</strong></li>
      </ul>
    </div>
    <ScrollCue client:visible label="Gulir" />
  </section>

  <!-- ============================ PROOF TICKER ============================ -->
  <section class="proof-ticker" aria-label="Poin kepercayaan BSM">
    <Marquee client:load duration={22} gap={48}>
      {proofTicks.map((t) => (
        <span class="proof-tick">
          <span class="proof-tick-dot" aria-hidden="true"></span>{t}
        </span>
      ))}
    </Marquee>
  </section>

  <!-- ============================ PRODUCTS ============================ -->
  <div class="section-divider" aria-hidden="true" data-texture="steel-beam">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,120 L0,80 Q360,0 720,60 Q1080,120 1440,40 L1440,120 Z" fill="var(--surface)"/>
    </svg>
  </div>
  <section id="produk" class="section section-soft section-cinematic">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Produk Inti</span>
        <h2 class="headline" data-word-reveal>Tiga material, satu pesanan.</h2>
        <p class="section-intro">Semua material ditarik langsung dari pabrik dan dikirim bersama ke lokasi proyek Anda.</p>
      </header>
      <div class="product-rows stagger-cinematic">
        {
          products.map((p, i) => (
            <article class:list={['product-row', i % 2 === 1 ? 'is-reversed' : '']}>
              <div class="product-media">
                <img src={p.photo} alt={`${p.name} — ${p.accent}`} width="1200" height="800" loading="lazy" decoding="async" />
                <span class="product-tag">{p.accent}</span>
              </div>
              <div class="product-copy">
                <span class="product-index">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="title">{p.name}</h3>
                <p>{p.spec}</p>
                <a class="product-link" href={`/produk/${p.slug}`}>{p.cta} <span aria-hidden="true">→</span></a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Divider: Products → One-Stop -->
  <div class="section-divider section-divider-reverse" aria-hidden="true" data-texture="wire-mesh">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L0,40 Q360,120 720,60 Q1080,0 1440,80 L1440,0 Z" fill="var(--surface)"/>
    </svg>
  </div>

  <section id="satu-atap" class="section section-red section-cinematic">
    <div class="container">
      <div class="onestop">
        <span class="eyebrow on-dark">Satu Atap</span>
        <h2 class="headline" data-word-reveal>Beberapa pabrik, satu pasokan.</h2>
        <p>Pabrik tidak menjual eceran. BSM menampung item sejenis dari beberapa pabrik sehingga Anda tak perlu menghubungi penyuplai satu per satu.</p>
        <a class="btn-on-red" href={wa('Halo BSM, saya ingin tahu cara kerja satu atap BSM.')}>Konsultasi via WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Divider: One-Stop → Advantages -->
  <div class="section-divider" aria-hidden="true" data-texture="corrugated-metal">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,120 L0,80 Q360,0 720,60 Q1080,120 1440,40 L1440,120 Z" fill="var(--surface)"/>
    </svg>
  </div>

  <section class="section section-soft section-cinematic">
    <div class="container">
      <ul class="advantage-grid stagger-cinematic">
        {
          advantages.map((a) => (
            <li class="advantage">
              <span class="advantage-check" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10.5L8 14.5L16 6.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <h3 class="title">{a.title}</h3>
              <p>{a.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Divider: Advantages → Coverage -->
  <div class="section-divider section-divider-reverse" aria-hidden="true" data-texture="concrete-wall">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L0,40 Q360,120 720,60 Q1080,0 1440,80 L1440,0 Z" fill="var(--surface)"/>
    </svg>
  </div>

  <section id="jangkauan" class="section section-cinematic">
    <div class="container">
      <div class="coverage-grid">
        <header class="section-head">
          <span class="eyebrow">Jangkauan</span>
          <h2 class="headline" data-word-reveal>Dari Sabang sampai Merauke</h2>
          <p class="section-intro">Pengadaan material proyek di seluruh nusantara — bukan hanya Jawa.</p>
        </header>
        <div class="coverage-map reveal">
          <IndonesiaMap client:visible />
        </div>
      </div>
      <div class="region-cloud">
        {regions.map((r) => <span class="region-tag">{r}</span>)}
      </div>
    </div>
  </section>

  <!-- Divider: Coverage → Gallery -->
  <div class="section-divider" aria-hidden="true">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,120 L0,80 Q360,0 720,60 Q1080,120 1440,40 L1440,120 Z" fill="var(--surface)"/>
    </svg>
  </div>

  <section id="galeri" class="section section-soft section-cinematic">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Galeri Proyek</span>
        <h2 class="headline" data-word-reveal>Material BSM di lapangan</h2>
      </header>
      <div class="gallery-grid stagger-cinematic">
        {gallery.map((src, i) => (
          <div class:list={['gallery-item', i === 0 ? 'gallery-wide' : '']}>
            <img src={src} alt="Dokumentasi proyek BSM" width="800" height="600" loading="lazy" decoding="async" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="kontak" class="section section-red cta-red section-cinematic">
    <div class="container cta-inner">
      <span class="eyebrow on-dark">Kontak</span>
      <h2 class="headline" data-word-reveal>Butuh penawaran untuk proyek Anda?</h2>
      <p>Hubungi tim BSM untuk konsultasi produk dan estimasi pengiriman ke lokasi proyek.</p>
      <div class="cta-actions">
        <a class="btn-on-red" href={wa('Halo BSM, saya ingin konsultasi & minta penawaran material proyek.')}>WhatsApp</a>
        <a class="btn btn-ghost on-dark" href={`mailto:${EMAIL}`}>Email kami</a>
      </div>
    </div>
  </section>

  {
    latest.length > 0 && (
      <section class="section section-cinematic">
        <div class="container">
          <header class="section-head">
            <span class="eyebrow">Blog</span>
            <h2 class="headline" data-word-reveal>Wawasan terbaru</h2>
            <p class="section-intro">Catatan proyek, material, dan pembaruan dari tim BSM.</p>
          </header>
          <ul class="post-list stagger-cinematic">
            {latest.map((post) => (
              <li class="post-item">
                <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
                <div class="post-meta">
                  <time datetime={new Date(post.data.pubDate).toISOString()}>
                    {new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {' · '}{post.data.category}
                </div>
              </li>
            ))}
          </ul>
          <a class="btn btn-ghost all-posts" href="/blog">Lihat semua artikel →</a>
        </div>
      </section>
    )
  }

  <script>
    import { initCinematic } from '../lib/cinematic';

    (() => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---- Initialize cinematic effects ----
      initCinematic();

      // ---- IntersectionObserver reveals ----
      const reveals = Array.from(document.querySelectorAll('.reveal, .stagger, .advantage, .hero-proof, .region-cloud'));
      if (reduce || !reveals.length) {
        reveals.forEach((el) => el.classList.add('is-in'));
      } else if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('is-in'));
      }
      window.addEventListener('load', () =>
        setTimeout(() => {
          document.querySelectorAll('.reveal:not(.is-in), .stagger:not(.is-in)').forEach((el) => el.classList.add('is-in'));
        }, 1200)
      );

      // ---- Parallax on scroll ----
      if (!reduce) {
        const parallaxElements = Array.from(document.querySelectorAll('.parallax-layer[data-parallax-speed]'));
        if (parallaxElements.length) {
          let ticking = false;
          function updateParallax() {
            const scrollY = window.scrollY;
            parallaxElements.forEach((el) => {
              const speed = parseFloat(el.dataset.parallaxSpeed) || 0.2;
              const rect = el.getBoundingClientRect();
              const centerY = rect.top + rect.height / 2;
              const offset = (window.innerHeight / 2 - centerY) * speed;
              el.style.transform = `translateY(${offset}px)`;
            });
            ticking = false;
          }
          window.addEventListener('scroll', () => {
            if (!ticking) {
              requestAnimationFrame(updateParallax);
              ticking = true;
            }
          }, { passive: true });
          updateParallax();
        }

        // ---- Mouse-reactive parallax on hero ----
        const heroMedia = document.querySelector('.hero-media');
        const heroImage = heroMedia?.querySelector('img');
        if (heroImage && heroMedia) {
          let mouseX = 0.5, mouseY = 0.5;
          let currentX = 0.5, currentY = 0.5;
          
          heroMedia.addEventListener('mousemove', (e) => {
            const rect = heroMedia.getBoundingClientRect();
            mouseX = (e.clientX - rect.left) / rect.width;
            mouseY = (e.clientY - rect.top) / rect.height;
          });
          
          heroMedia.addEventListener('mouseleave', () => {
            mouseX = 0.5;
            mouseY = 0.5;
          });
          
          function updateHeroParallax() {
            currentX += (mouseX - currentX) * 0.08;
            currentY += (mouseY - currentY) * 0.08;
            const moveX = (currentX - 0.5) * 20;
            const moveY = (currentY - 0.5) * 20;
            heroImage.style.transform = `translate(${moveX}px, ${moveY}px) scale(1.05)`;
            requestAnimationFrame(updateHeroParallax);
          }
          updateHeroParallax();
        }

        // ---- Cursor spotlight on CTA section ----
        const ctaSection = document.querySelector('.cta-red');
        if (ctaSection) {
          ctaSection.addEventListener('mousemove', (e) => {
            const rect = ctaSection.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            ctaSection.style.setProperty('--spotlight-x', `${x}px`);
            ctaSection.style.setProperty('--spotlight-y', `${y}px`);
          });
          
          ctaSection.addEventListener('mouseleave', () => {
            ctaSection.style.setProperty('--spotlight-x', '50%');
            ctaSection.style.setProperty('--spotlight-y', '50%');
          });
        }
      }
    })();
  </script>

</Base>
