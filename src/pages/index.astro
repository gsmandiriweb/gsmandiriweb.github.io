  <script>
    // --- Robust scroll reveals (the Jangkauan map and other sections) ---
    // Content is visible by default (CSS). With JS, .reveal starts hidden and
    // fades in via IntersectionObserver. A failsafe reveals anything still
    // hidden shortly after load so content is NEVER trapped invisible if the
    // observer is throttled (background tab, headless, blocked GSAP).
    (() => {
      const reveals = Array.from(document.querySelectorAll('.reveal, .stagger'));
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !reveals.length) { reveals.forEach((el) => el.classList.add('is-in')); }
      else if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('is-in'));
      }
      // Failsafe: if anything is still hidden after load settles, show it.
      window.addEventListener('load', () => setTimeout(() => {
        document.querySelectorAll('.reveal:not(.is-in), .stagger:not(.is-in)').forEach((el) => el.classList.add('is-in'));
      }, 1200));
    })();

    // Lazy-load scroll-tied motion flourishes (GSAP) after paint. Guarded so a
    // failed/blocked import can never affect content visibility (reveals above
    // are handled independently of GSAP).
    window.addEventListener('load', () => {
      import('../scripts/scroll-anim')
        .then((m) => m.initScrollAnim())
        .catch(() => {});
    });

    // Progressive enhancement for the Motion Core Globe: only show it (and hide
    // the map fallback) once its WebGL canvas is actually drawing. If WebGL is
    // blocked, throttled, or slow, the map stays — the section is never blank.
    (() => {
      const wrap = document.querySelector('.globe-wrap');
      const fallback = document.querySelector('.globe-fallback');
      if (!wrap || !fallback) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const start = Date.now();
      const check = () => {
        const c = wrap.querySelector('canvas');
        if (c && c.width > 320 && c.height > 160) {
          wrap.classList.add('is-active');
          fallback.classList.add('is-hidden');
          return;
        }
        if (Date.now() - start > 4000) return; // give up; keep the map
        requestAnimationFrame(check);
      };
      check();
    })();
  </script>

