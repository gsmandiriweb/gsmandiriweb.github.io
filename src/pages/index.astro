---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { waLink as wa, EMAIL } from '../config/contact';
import {
  Magnetic, SplitReveal, Halo, TextLoop, MacosDock, StackingWords,
  Marquee, SplitHover, FlipGrid, WeightWave, Globe, InteractiveGrid,
} from '../lib/motion-core';

const all = await getCollection('blog');
const now = Date.now();
const latest = all
  .filter((p) => !p.data.trashed && new Date(p.data.pubDate).getTime() <= now)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const products = [
  {
    name: 'Pagar BRC',
    kind: 'brc' as const,
    accent: 'Besi BRC',
    photo: '/photos/IMG_4077.webp',
    spec: 'Besi beton berkualitas · Standar SNI · Finishing HDG anti-karat untuk ketahanan jangka panjang di lapangan.',
  },
  {
    name: 'Kawat Duri',
    kind: 'wire' as const,
    accent: 'Kawat Duri',
    photo: '/photos/IMG_4068.webp',
    spec: 'Galvanis tahan cuaca · Roll panjang siap kirim untuk pagar pengaman proyek, lahan, dan perimeter.',
  },
  {
    name: 'Guard Rail',
    kind: 'rail' as const,
    accent: 'Guard Rail',
    photo: '/photos/IMG_4085.webp',
    spec: 'Pagar pengaman jalan · Material tebal · Memenuhi standar perkerasan SNI untuk konstruksi jalan raya.',
  },
];

const advantages = [
  {
    title: 'Harga langsung dari pabrik',
    body: 'BSM menampung produk dari beberapa pabrik sejenis, sehingga kontraktor mendapat satu sumber dengan harga pabrik — bukan harga eceran.',
  },
  {
    title: 'Satu sumber, banyak kebutuhan',
    body: 'Besi BRC, kawat duri, dan guard rail dalam satu pesanan. Satu mitra, satu administrasi, satu pengiriman ke lokasi proyek.',
  },
  {
    title: 'Stok lengkap & siap kirim',
    body: 'Gudang terisi dan logistik handal memastikan material tersedia tepat waktu, kapan pun proyek Anda butuh.',
  },
  {
    title: 'Jaminan kualitas & SNI',
    body: 'Setiap produk melewati seleksi ketat dan memenuhi standar SNI dengan lapisan anti-karat HDG.',
  },
];

const regions = [
  'Surabaya', 'Jakarta', 'Sidoarjo', 'Gresik', 'Malang', 'Semarang',
  'Yogyakarta', 'Bandung', 'Kalimantan', 'Sulawesi', 'Papua', 'Sumatera',
];

const factories = ['Pabrik BRC', 'Pabrik Kawat', 'Pabrik Rail'];

// Nationwide coverage markers for the Motion Core Globe — real Indonesian
// cities [lat, lon], Sabang → Merauke. Light-teal pins on a teal atmosphere.
const cities = [
  { location: [5.89, 95.32] as [number, number], color: '#aef4fb', size: 0.07, label: 'Sabang' },
  { location: [3.59, 98.67] as [number, number], color: '#aef4fb', size: 0.06, label: 'Medan' },
  { location: [-0.95, 100.35] as [number, number], color: '#aef4fb', size: 0.06, label: 'Padang' },
  { location: [-2.99, 104.76] as [number, number], color: '#aef4fb', size: 0.06, label: 'Palembang' },
  { location: [-6.21, 106.85] as [number, number], color: '#aef4fb', size: 0.07, label: 'Jakarta' },
  { location: [-6.91, 107.61] as [number, number], color: '#aef4fb', size: 0.06, label: 'Bandung' },
  { location: [-6.99, 110.42] as [number, number], color: '#aef4fb', size: 0.06, label: 'Semarang' },
  { location: [-7.8, 110.36] as [number, number], color: '#aef4fb', size: 0.06, label: 'Yogyakarta' },
  { location: [-7.26, 112.75] as [number, number], color: '#aef4fb', size: 0.07, label: 'Surabaya' },
  { location: [-3.32, 114.59] as [number, number], color: '#aef4fb', size: 0.06, label: 'Banjarmasin' },
  { location: [-0.03, 109.33] as [number, number], color: '#aef4fb', size: 0.06, label: 'Pontianak' },
  { location: [-5.15, 119.43] as [number, number], color: '#aef4fb', size: 0.07, label: 'Makassar' },
  { location: [-8.65, 115.22] as [number, number], color: '#aef4fb', size: 0.06, label: 'Denpasar' },
  { location: [-10.17, 123.58] as [number, number], color: '#aef4fb', size: 0.06, label: 'Kupang' },
  { location: [1.49, 124.85] as [number, number], color: '#aef4fb', size: 0.06, label: 'Manado' },
  { location: [-3.7, 128.18] as [number, number], color: '#aef4fb', size: 0.06, label: 'Ambon' },
  { location: [-2.53, 140.72] as [number, number], color: '#aef4fb', size: 0.07, label: 'Jayapura' },
  { location: [-8.47, 140.4] as [number, number], color: '#aef4fb', size: 0.07, label: 'Merauke' },
];

// One-stop dock — magnetic product shortcuts (Motion Core MacosDock).
const dockItems = [
  { src: '/icons/pagar-brc.svg', alt: 'Pagar BRC', label: 'Pagar BRC', href: '#produk' },
  { src: '/icons/kawat-duri.svg', alt: 'Kawat Duri', label: 'Kawat Duri', href: '#produk' },
  { src: '/icons/guard-rail.svg', alt: 'Guard Rail', label: 'Guard Rail', href: '#produk' },
  { src: '/icons/whatsapp.svg', alt: 'WhatsApp', label: 'WhatsApp', href: wa('Halo BSM, saya ingin minta penawaran material proyek.') },
];

// Curated gallery from the real site photos.
const gallery = [
  '/photos/IMG_4077.webp',
  '/photos/IMG_4085.webp',
  '/photos/IMG_4068.webp',
  '/photos/IMG_4082.webp',
  '/photos/IMG_4071.webp',
  '/photos/IMG_4086.webp',
  '/photos/IMG_4078.webp',
  '/photos/IMG_4064.webp',
];
---

<Base
  title="CV Bangun Sarana Makmur — Distributor Material Konstruksi One-Stop"
  description="BSM menampung besi BRC, kawat duri, dan guard rail dari beberapa pabrik menjadi satu sumber andal untuk proyek Anda. Melayani seluruh Indonesia."
>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-halo" aria-hidden="true">
      <Halo
        client:visible
        scale={1.1}
        rotationSpeed={0.35}
        backgroundColor="#0b1a1f"
        sunZ={1}
        intensity={0.9}
      />
    </div>
    <div class="container hero-grid">
      <div class="hero-copy reveal">
        <span class="eyebrow">Distributor Material Konstruksi</span>
        <span class="hero-tagline">
          Solusi untuk
          <TextLoop
            client:visible
            class="hero-tagline-loop"
            texts={['pagar proyek', 'kawat duri', 'guard rail', 'kebutuhan baja']}
            interval={2200}
          />
        </span>
        <h1>
          <SplitReveal mode="lines" client:load>
            Satu <span class="hl">sumber</span> untuk kebutuhan material proyek Anda
          </SplitReveal>
        </h1>
        <p class="hero-lead">
          Kami menampung besi BRC, kawat duri, dan guard rail dari beberapa pabrik menjadi
          <strong>satu suplai one-stop</strong> untuk kontraktor dan proyek di seluruh Indonesia.
        </p>
        <div class="hero-cta">
          <Magnetic duration={0.6} ease="power3.out" client:load>
            <SplitHover client:visible>
              <a class="btn btn-primary" href={wa('Halo BSM, saya ingin minta penawaran untuk material proyek.')}>
                Hubungi via WhatsApp
              </a>
            </SplitHover>
          </Magnetic>
          <a class="btn btn-ghost" href="#produk">Lihat produk</a>
        </div>
        <ul class="hero-stats">
          <li><span class="stat-num">10+</span><span class="stat-label">Tahun</span></li>
          <li><span class="stat-num">SNI</span><span class="stat-label">Terstandarisasi</span></li>
          <li><span class="stat-num">S–M</span><span class="stat-label">Sabang–Merauke</span></li>
        </ul>
        <div class="hero-dock" aria-label="Pintasan produk BSM">
          <MacosDock client:visible items={dockItems} baseWidth={3.4} magnification={1.7} distance={2.4} />
        </div>
      </div>

      <div class="hero-media reveal">
        <!-- Real site photo with a mouse-reactive grid shader (motion-core).
             Reduced-motion users get the plain photo; the shader only mounts
             when motion is allowed. -->
        <img
          src="/photos/IMG_4077.webp"
          alt="Proyek konstruksi BSM: material pagar dan struktur baja di lokasi"
          width="1600" height="1067" loading="eager" decoding="async"
        />
        <InteractiveGrid
          client:visible
          class="hero-grid-shader"
          image="/photos/IMG_4077.webp"
          grid={18}
          mouseSize={0.16}
          strength={0.28}
        />
        <span class="hero-stamp">Satu Sumber · One-Stop</span>
      </div>
    </div>
  </section>

  <!-- ============================ PROOF STRIP ============================ -->
  <section class="proof">
    <div class="proof-inner">
      <p class="proof-lead">
        <WeightWave client:visible baseWeight={380} hoverWeight={780} influenceRadius={4}>
          <strong>Terpercaya</strong> untuk proyek &amp; instansi pemerintah di seluruh Indonesia.
        </WeightWave>
      </p>
      <ul class="proof-facts">
        <li><span class="fact-mark" aria-hidden="true"></span>10+ tahun</li>
        <li><span class="fact-mark" aria-hidden="true"></span>Standar SNI</li>
        <li><span class="fact-mark" aria-hidden="true"></span>Sabang–Merauke</li>
        <li><span class="fact-mark" aria-hidden="true"></span>Langsung dari pabrik</li>
      </ul>
    </div>
  </section>


  <!-- ============================ PRODUK ============================ -->
  <section id="produk" class="section">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Produk Inti</span>
        <h2><StackingWords client:load>Three materials, one order</StackingWords></h2>
        <p class="section-intro">
          Ditarik langsung dari pabrik dan dikirim sebagai satu pengiriman ke lokasi proyek Anda.
        </p>
      </header>
      <div class="product-list">
        {
          products.map((p, i) => (
            <article class="product-row reveal" class:list={[i % 2 === 1 && 'reverse']}>
              <div class="product-media">
                <img src={p.photo} alt={`${p.name} — ${p.accent}`} width="1200" height="800" loading="lazy" decoding="async" />
                <span class="product-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="product-copy">
                <span class="product-kicker">{p.accent}</span>
                <h3>{p.name}</h3>
                <p>{p.spec}</p>
                <a class="btn btn-primary" href={wa(`Halo BSM, saya ingin minta penawaran untuk ${p.name}.`)}>
                  Minta penawaran
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>


  <!-- ============================ SATU ATAP / ONE-STOP ============================ -->
  <section id="satu-atap" class="section section-soft">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Satu Atap</span>
        <h2><StackingWords client:load>Several factories. One supply.</StackingWords></h2>
        <p class="section-intro">
          Pabrik tidak menjual eceran. BSM menggabungkan beberapa item sejenis menjadi satu
          pasokan andal — Anda tak perlu menghubungi pabrik demi pabrik.
        </p>
      </header>

      <div class="flow reveal">
        <div class="flow-col">
          <p class="flow-label">Penyuplai</p>
          <ul class="flow-list">
            {factories.map((f) => (
              <li><span class="node-dot" aria-hidden="true"></span>{f}</li>
            ))}
          </ul>
        </div>
        <div class="flow-arrow" aria-hidden="true">
          <span class="flow-core">BSM<span class="flow-ring"></span></span>
        </div>
        <div class="flow-col">
          <p class="flow-label">Untuk Anda</p>
          <ul class="flow-list">
            {['Satu pesanan', 'Satu administrasi', 'Satu pengiriman'].map((o) => (
              <li class="out"><span class="node-dot red" aria-hidden="true"></span>{o}</li>
            ))}
          </ul>
        </div>
      </div>

      <ul class="advantage-grid stagger">
        {
          advantages.map((a) => (
            <li class="advantage">
              <span class="advantage-num" aria-hidden="true">{String(advantages.indexOf(a) + 1).padStart(2, '0')}</span>
              <h3>{a.title}</h3>
              <p>{a.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============================ JANGKAUAN ============================ -->
  <section id="jangkauan" class="section section-coverage">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Jangkauan</span>
        <h2><StackingWords client:load>Dari Sabang sampai Merauke</StackingWords></h2>
        <p class="section-intro">
          BSM melayani pengadaan material proyek di seluruh nusantara — bukan hanya Jawa.
          Titik-titik di bawah menandai kota yang telah menjadi mitra pengiriman kami,
          dari ujung barat hingga timur Indonesia.
        </p>
      </header>
      <div class="coverage-grid reveal">
        <div class="globe-stage">
          <!-- Robust default: the de-cluttered Indonesia map, inlined so it
               always renders (no SVG-via-img network/font dependency). -->
          <svg
            class="globe-fallback"
            viewBox="0 0 1411 520"
            role="img"
            aria-label="Peta jangkauan pengiriman BSM di seluruh Indonesia, dari Sabang sampai Merauke"
            xmlns="http://www.w3.org/2000/svg"
          >
            <g class="map-land">
              <path d="M781.6,492.4 769,493 729.5,472.1 757.3,466.2 772.9,475.3 783.3,484.4 Z" />
              <path d="M892.4,489.4 866.9,496 863.3,492.4 866,482.3 878.8,464.1 908.3,452.3 911.3,458.2 911.9,467.2 Z" />
              <path d="M697.7,428.5 708.4,436.5 726.8,434 734.2,446.7 699.7,452.7 679.1,456.7 663.1,456.5 673.3,439.3 689.7,439.1 Z" />
              <path d="M846.7,428.5 842.4,445 797.6,453.5 758,449.8 757.9,438.9 781.5,432.7 800.2,441.7 820,439.4 Z" />
              <path d="M421.2,389.3 478.3,392.2 484.9,379.9 540.2,394.3 551,413.6 595.7,419 632.3,436.7 598.3,448.1 565.5,436.1 538.5,436.9 507.6,434.7 479.7,429.3 445.2,417.9 423.3,415 410.9,418.7 356.6,406.5 351.4,393.6 324.1,391.5 344.6,363 380.7,364.7 404.8,376.4 417.2,378.7 Z" />
              <path d="M1199,372.5 1183.7,392.8 1180.8,370.3 1186.1,359.6 1192.3,349.5 1199.1,358.3 Z" />
              <path d="M976.2,290.4 965.1,300.3 944.5,294.8 938.7,282 968.8,280.5 Z" />
              <path d="M1072.3,279.5 1083.1,302.3 1057.9,290 1033,287.5 1016.2,289.5 995.6,288.4 1002.7,272 1039.5,270.8 Z" />
              <path d="M1181.7,221.6 1190,269.8 1220.8,287.6 1245.7,256 1279.9,238.1 1306.4,238 1331.9,248.4 1354,259.1 1386,264.8 1386.5,361.9 1387,459 1360.5,434.5 1330.2,428.5 1322.9,437 1285.1,437.9 1297.8,413.7 1316.5,405.4 1308.8,373 1294.4,348 1236.7,322.8 1212.1,320.3 1167.4,292.7 1158.6,307.2 1147.1,309.8 1140.4,298.9 1140.3,286 1117.5,271.3 1149.6,260.6 1170.8,261.2 1168.4,253.3 1124.7,253.2 1112.9,235.5 1086.3,230 1073.7,215.2 1113.9,208 1129.1,198.3 1177,210.5 Z" />
              <path d="M916.4,145 892.4,174.5 870,180.3 841.4,174.4 791.7,175.9 765.7,180.2 761.4,202.8 788.1,229.3 804.2,215.8 859.8,205.6 857.3,219.4 844.3,215 831.4,232.5 805.2,244 833.4,282.2 827.9,292.5 854.7,326.9 854.5,346.4 838.6,355.2 826.9,344.7 841.3,320.3 812,331.9 804.6,323.6 808.5,312.1 787,294.6 789.2,265.6 769.3,274.6 771.8,309.4 773.1,352 754.2,356.3 741.4,347.6 749.9,320.2 745.3,291.4 732.8,291.2 723.5,270.8 735.8,251.3 740.1,227.6 755,182.7 761.3,170.4 786.6,148.3 809.9,157.1 847.5,161.2 881.7,160 911.2,138.3 Z" />
              <path d="M1019.1,153.5 1017.6,179.6 1002.2,176.7 997.7,194.8 1009.9,210.5 1001.6,214.1 989.6,195.2 980.7,157.1 986.7,133.3 996.6,122.5 998.7,138.8 1016.3,141.4 Z" />
              <path d="M696.9,132.8 730.3,160.4 695,163.9 685.1,184.2 686.4,211.2 657.7,231.6 656.9,261.3 645.4,306.9 641.1,296.3 607.2,309.7 595.4,291.5 574.2,289.8 559.3,280.2 523.9,290.9 513,276.5 493.5,278.2 468.9,274.7 464.4,234.8 449.5,226.5 435.2,201 431,174.9 434.5,147.3 452.2,127.5 457.2,147.4 477.6,164.3 496.8,158.2 515.8,160.3 533.2,145.3 547.5,142.7 575.7,151 600,144.7 615.2,103.2 626.7,92.9 637,59 671.3,59 697.1,64 680.2,90.9 702.1,119.1 Z" />
              <path d="M337.6,361.7 304.6,362.3 279.5,337.4 241.3,313 228.5,295 206,270.7 191.2,248.4 168.5,206.7 142.3,181.8 133.6,156.2 122.6,133 95.7,114.2 80.1,88.7 57.7,72 26.6,39.2 24,24 43.2,25.2 89.3,31 115.7,60.1 138.7,80.3 155.1,92.7 183.4,124.7 213.7,125.2 238.7,145.6 255.9,170.6 278.6,184.2 266.7,208.5 283.8,218.9 294.5,219.6 299.5,240.4 309.9,257 331.8,259.7 346.3,278.5 338.8,315.6 Z" />
            </g>
            <g class="map-dot">
              <circle cx="544.2" cy="403.3" r="6.5" /><circle cx="368.4" cy="372" r="6.5" /><circle cx="543.3" cy="409.3" r="6.5" /><circle cx="540.6" cy="400.6" r="6.5" /><circle cx="540.6" cy="425.1" r="6.5" /><circle cx="475.1" cy="395" r="6.5" /><circle cx="473" cy="419.7" r="6.5" /><circle cx="391.3" cy="392.9" r="6.5" /><circle cx="581.4" cy="232" r="7.5" /><circle cx="775.1" cy="276.7" r="7.5" /><circle cx="1371.1" cy="321.4" r="7.5" /><circle cx="194.1" cy="202.2" r="7.5" />
            </g>
            <g class="map-ring">
              <circle cx="544.2" cy="403.3" r="9.5" /><circle cx="368.4" cy="372" r="9.5" /><circle cx="543.3" cy="409.3" r="9.5" /><circle cx="540.6" cy="400.6" r="9.5" /><circle cx="540.6" cy="425.1" r="9.5" /><circle cx="475.1" cy="395" r="9.5" /><circle cx="473" cy="419.7" r="9.5" /><circle cx="391.3" cy="392.9" r="9.5" /><circle cx="581.4" cy="232" r="11" /><circle cx="775.1" cy="276.7" r="11" /><circle cx="1371.1" cy="321.4" r="11" /><circle cx="194.1" cy="202.2" r="11" />
            </g>
          </svg>
          <!-- Motion Core Globe: rotating coverage with city markers.
              Progressive enhancement — revealed only when its canvas draws. -->
          <div class="globe-wrap" aria-hidden="true">
            <Globe
              client:visible
              markers={cities}
              landPointColor="#6fcfd8"
              pointCount={14000}
              pointSize={0.06}
              autoRotate={true}
              fresnelConfig={{ color: '#17181A', rimColor: '#19bcc9', rimPower: 6, rimIntensity: 1.6 }}
              atmosphereConfig={{ color: '#19bcc9', scale: 1.18, power: 12, coefficient: 0.9, intensity: 1.4 }}
            />
          </div>
        </div>
      </div>
    </div>
    <div class="marquee coverage-marquee" aria-hidden="true">
      <Marquee client:visible gap={40} duration={26} repeat={4}>
        {regions.map((r) => (
          <span class="marquee-item">{r}</span>
        ))}
      </Marquee>
    </div>
  </section>


  <!-- ============================ GALERI PROYEK ============================ -->
  <section id="galeri" class="section">
    <div class="container">
      <header class="section-head reveal">
        <span class="eyebrow">Galeri Proyek</span>
        <h2><StackingWords client:load>BSM materials on site</StackingWords></h2>
        <p class="section-intro">Dokumentasi langsung dari proyek dan lokasi pengiriman kami di seluruh Indonesia.</p>
      </header>
      <FlipGrid client:visible columns={4} class="gallery-grid" duration={0.6}>
        {
          gallery.map((src, i) => (
            <li class="gallery-item gallery-reveal" style={`--i:${i}`}>
              <img src={src} alt="Dokumentasi proyek BSM" width="800" height="600" loading="lazy" decoding="async" />
            </li>
          ))
        }
      </FlipGrid>
    </div>
  </section>


  <!-- ============================ CTA BAND ============================ -->
  <section id="kontak" class="cta-band">
    <div class="container cta-inner reveal">
      <span class="eyebrow on-dark">Kontak</span>
      <h2><StackingWords client:load>Need a quote for your project?</StackingWords></h2>
      <p>Hubungi tim BSM untuk konsultasi produk dan estimasi pengiriman ke lokasi proyek.</p>
      <div class="cta-actions">
        <a class="btn btn-primary on-light" href={wa('Halo BSM, saya ingin konsultasi & minta penawaran material proyek.')}>WhatsApp</a>
        <a class="btn btn-ghost on-dark" href={`mailto:${EMAIL}`}>Email kami</a>
      </div>
    </div>
  </section>

  <!-- ============================ BLOG ============================ -->
  {
    latest.length > 0 && (
      <section class="section section-soft">
        <div class="container">
          <header class="section-head reveal">
            <span class="eyebrow">Blog</span>
            <h2>Wawasan terbaru</h2>
